{
  "permissions": {
    "allow": ["mcp__*", "Read", "Write", "Edit", "Bash", "Glob", "Grep"],
    "deny": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["context7", "playwright"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/scripts/pre-commit-hook.py '$ARGUMENTS'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/scripts/stop-hook.py",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/scripts/session-start-hook.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
